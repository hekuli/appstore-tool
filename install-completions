#!/bin/bash
set -euo pipefail

TOOL="./bin/appstore-tool"

if [[ ! -x "$TOOL" ]]; then
    echo "Error: $TOOL not found. Run ./build first."
    exit 1
fi

# Zsh
ZSH_COMPLETIONS_DIR="${HOME}/.zsh/completions"
mkdir -p "$ZSH_COMPLETIONS_DIR"
"$TOOL" --generate-completion-script zsh > "$ZSH_COMPLETIONS_DIR/_appstore-tool"
echo "Installed zsh completions to $ZSH_COMPLETIONS_DIR/_appstore-tool"

# Bash
BASH_COMPLETIONS_DIR="${HOME}/.local/share/bash-completion/completions"
mkdir -p "$BASH_COMPLETIONS_DIR"
"$TOOL" --generate-completion-script bash > "$BASH_COMPLETIONS_DIR/appstore-tool"
echo "Installed bash completions to $BASH_COMPLETIONS_DIR/appstore-tool"

# Fish
FISH_COMPLETIONS_DIR="${HOME}/.config/fish/completions"
mkdir -p "$FISH_COMPLETIONS_DIR"
"$TOOL" --generate-completion-script fish > "$FISH_COMPLETIONS_DIR/appstore-tool.fish"
echo "Installed fish completions to $FISH_COMPLETIONS_DIR/appstore-tool.fish"

echo ""
echo "For zsh, ensure ~/.zsh/completions is in your fpath. Add this to ~/.zshrc if needed:"
echo '  fpath=(~/.zsh/completions $fpath)'
echo '  autoload -Uz compinit && compinit'
echo ""
echo "Restart your shell or run: exec \$SHELL"
